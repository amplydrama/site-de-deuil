<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deuil — Djoudjieu Jeannette épse Tapondjou</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --noir: #1a1614;
    --or: #c9a84c;
    --or-clair: #e8d5a0;
    --creme: #f5f0e8;
    --gris: #6b6460;
    --blanc: #fdfcfa;
    --rouge-deuil: #8b2e2e;
    --vert-deuil: #2e5c3e;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--noir);
    color: var(--creme);
    min-height: 100vh;
  }

  /* NAV */
  nav {
    background: rgba(26,22,20,0.97);
    border-bottom: 1px solid rgba(201,168,76,0.3);
    padding: 0 2rem;
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .nav-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    color: var(--or);
    font-style: italic;
  }
  .nav-tabs { display: flex; gap: 0; }
  .nav-tab {
    padding: 0 1.2rem; height: 64px;
    display: flex; align-items: center;
    cursor: pointer; font-size: 0.78rem;
    letter-spacing: 0.05em; font-weight: 500;
    color: var(--gris);
    border-bottom: 2px solid transparent;
    transition: all 0.2s; text-transform: uppercase;
    white-space: nowrap;
  }
  .nav-tab:hover { color: var(--or-clair); }
  .nav-tab.active { color: var(--or); border-bottom-color: var(--or); }

  /* MAIN */
  main { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem; }

  /* PAGES */
  .page { display: none; }
  .page.active { display: block; }

  /* HEADER DE PAGE */
  .page-header {
    text-align: center;
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid rgba(201,168,76,0.2);
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem; font-weight: 300;
    color: var(--or); letter-spacing: 0.03em;
  }
  .page-header p { color: var(--gris); font-size: 0.85rem; margin-top: 0.5rem; }

  /* CARDS */
  .card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 4px;
    padding: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem; color: var(--or);
    margin-bottom: 1rem; font-weight: 400;
  }

  /* STATS */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem; margin-bottom: 2rem;
  }
  .stat-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 4px; padding: 1.2rem 1.5rem;
    text-align: center;
  }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gris); }
  .stat-value { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--or); margin: 0.3rem 0; }
  .stat-sub { font-size: 0.75rem; color: var(--gris); }

  /* FORM */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-group.full { grid-column: 1 / -1; }
  label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gris); }
  input, select, textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(201,168,76,0.2);
    border-radius: 3px; padding: 0.7rem 1rem;
    color: var(--creme); font-size: 0.9rem;
    font-family: 'Montserrat', sans-serif;
    transition: border-color 0.2s;
    outline: none;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--or); }
  select option { background: var(--noir); }
  textarea { resize: vertical; min-height: 80px; }

  /* BUTTONS */
  .btn {
    padding: 0.7rem 1.8rem; border: none; border-radius: 3px;
    cursor: pointer; font-family: 'Montserrat', sans-serif;
    font-size: 0.82rem; font-weight: 500; letter-spacing: 0.05em;
    transition: all 0.2s; text-transform: uppercase;
  }
  .btn-or {
    background: var(--or); color: var(--noir);
  }
  .btn-or:hover { background: var(--or-clair); }
  .btn-outline {
    background: transparent;
    border: 1px solid rgba(201,168,76,0.4);
    color: var(--or);
  }
  .btn-outline:hover { border-color: var(--or); background: rgba(201,168,76,0.08); }
  .btn-danger {
    background: transparent;
    border: 1px solid rgba(139,46,46,0.4);
    color: #c97070; font-size: 0.75rem; padding: 0.4rem 0.8rem;
  }
  .btn-danger:hover { background: rgba(139,46,46,0.15); }
  .btn-sm { padding: 0.45rem 1rem; font-size: 0.75rem; }

  .actions { display: flex; gap: 0.8rem; flex-wrap: wrap; margin-top: 1.2rem; }

  /* TABLE */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  th {
    text-align: left; padding: 0.7rem 1rem;
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--gris); border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  td {
    padding: 0.8rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: var(--creme);
  }
  tr:hover td { background: rgba(255,255,255,0.03); }

  /* BADGES */
  .badge {
    display: inline-block; padding: 0.2rem 0.6rem;
    border-radius: 20px; font-size: 0.72rem; font-weight: 500;
  }
  .badge-village { background: rgba(46,92,62,0.3); color: #7fc49a; border: 1px solid rgba(46,92,62,0.5); }
  .badge-ville { background: rgba(46,92,139,0.3); color: #7aa8d4; border: 1px solid rgba(46,92,139,0.5); }
  .badge-partout { background: rgba(139,100,46,0.3); color: var(--or-clair); border: 1px solid rgba(139,100,46,0.5); }
  .badge-entree { background: rgba(46,92,62,0.3); color: #7fc49a; border: 1px solid rgba(46,92,62,0.5); }
  .badge-depense { background: rgba(139,46,46,0.3); color: #c97070; border: 1px solid rgba(139,46,46,0.5); }

  /* SHARE LINK */
  .share-box {
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 4px; padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .share-box h3 { font-family: 'Cormorant Garamond', serif; color: var(--or); font-size: 1.2rem; margin-bottom: 0.8rem; }
  .link-row { display: flex; gap: 0.8rem; align-items: center; flex-wrap: wrap; }
  .link-input {
    flex: 1; min-width: 200px;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(201,168,76,0.3);
    border-radius: 3px; padding: 0.7rem 1rem;
    color: var(--or-clair); font-size: 0.82rem;
    font-family: monospace;
  }

  /* FORMULAIRE PUBLIC (simulé) */
  .public-form-preview {
    background: var(--blanc); color: var(--noir);
    border-radius: 6px; padding: 2rem;
    max-width: 550px; margin: 0 auto;
  }
  .public-form-preview h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; text-align: center;
    color: var(--noir); margin-bottom: 0.5rem;
  }
  .public-form-preview p { text-align: center; color: #666; font-size: 0.85rem; margin-bottom: 1.5rem; }
  .public-form-preview label { color: #333; }
  .public-form-preview input,
  .public-form-preview select,
  .public-form-preview textarea {
    background: #f9f9f9; color: var(--noir);
    border: 1px solid #ddd;
  }
  .public-form-preview input:focus,
  .public-form-preview select:focus { border-color: var(--or); }
  .public-form-preview select option { background: white; }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.8); z-index: 200;
    align-items: center; justify-content: center;
    padding: 1rem;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: #231f1d; border: 1px solid rgba(201,168,76,0.3);
    border-radius: 6px; width: 100%; max-width: 600px;
    max-height: 90vh; overflow-y: auto;
    padding: 2rem;
  }
  .modal-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 1.5rem;
  }
  .modal-title { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--or); }
  .modal-close { background: none; border: none; color: var(--gris); font-size: 1.5rem; cursor: pointer; }
  .modal-close:hover { color: var(--creme); }

  /* EMPTY STATE */
  .empty {
    text-align: center; padding: 3rem 1rem;
    color: var(--gris); font-size: 0.9rem;
    font-style: italic;
  }

  /* TOAST */
  #toast {
    position: fixed; bottom: 2rem; right: 2rem;
    background: var(--or); color: var(--noir);
    padding: 0.8rem 1.5rem; border-radius: 4px;
    font-size: 0.85rem; font-weight: 500;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s; z-index: 300;
  }
  #toast.show { opacity: 1; }

  .divider { border: none; border-top: 1px solid rgba(201,168,76,0.15); margin: 1.5rem 0; }
  .text-or { color: var(--or); }
  .text-gris { color: var(--gris); }
  .mt-1 { margin-top: 1rem; }
  .montant-pos { color: #7fc49a; }
  .montant-neg { color: #c97070; }

  @media (max-width: 600px) {
    .form-grid { grid-template-columns: 1fr; }
    .form-grid.cols-3 { grid-template-columns: 1fr; }
    nav { padding: 0 0.8rem; }
    .nav-tab { padding: 0 0.6rem; font-size: 0.7rem; }
    .nav-title { font-size: 1.1rem; }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-title">✦ Deuil de Maman</div>
  <div class="nav-tabs">
    <div class="nav-tab active" onclick="showPage('dashboard')">Tableau de bord</div>
    <div class="nav-tab" onclick="showPage('finances')">Finances</div>
    <div class="nav-tab" onclick="showPage('participants')">Participants</div>
    <div class="nav-tab" onclick="showPage('formulaire')">Formulaire</div>
  </div>
</nav>

<main>

  <!-- ========== DASHBOARD ========== -->
  <div class="page active" id="page-dashboard">
    <div class="page-header">
      <h1>En mémoire de Maman</h1>
      <p style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--or-clair);font-style:italic;margin-top:0.3rem;">Djoudjieu Jeannette épouse Tapondjou</p>
      <p id="dash-date" class="text-gris"></p>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Entrées</div>
        <div class="stat-value montant-pos" id="stat-entrees">0 FCFA</div>
        <div class="stat-sub">Contributions reçues</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Dépenses</div>
        <div class="stat-value montant-neg" id="stat-depenses">0 FCFA</div>
        <div class="stat-sub">Charges engagées</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Solde</div>
        <div class="stat-value" id="stat-solde">0 FCFA</div>
        <div class="stat-sub">Balance actuelle</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Participants</div>
        <div class="stat-value text-or" id="stat-participants">0</div>
        <div class="stat-sub">Inscrits via formulaire</div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;">
      <div class="card">
        <div class="card-title">Dernières transactions</div>
        <div id="dash-transactions"><div class="empty">Aucune transaction</div></div>
      </div>
      <div class="card">
        <div class="card-title">Répartition participants</div>
        <div id="dash-repartition" style="font-size:0.9rem;"></div>
      </div>
    </div>
  </div>

  <!-- ========== FINANCES ========== -->
  <div class="page" id="page-finances">
    <div class="page-header">
      <h1>Finances</h1>
      <p>Suivi des entrées et dépenses du deuil</p>
    </div>

    <div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <button class="btn btn-or" onclick="openModal('modal-transaction')">+ Nouvelle transaction</button>
    </div>

    <div class="card">
      <div class="card-title">Toutes les transactions</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th><th>Type</th><th>Catégorie</th><th>Description</th><th>Montant</th><th>Action</th>
            </tr>
          </thead>
          <tbody id="finance-table"><tr><td colspan="6" class="empty">Aucune transaction enregistrée</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ========== PARTICIPANTS ========== -->
  <div class="page" id="page-participants">
    <div class="page-header">
      <h1>Participants</h1>
      <p>Personnes qui assistent au deuil</p>
    </div>

    <div style="display:flex;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap;">
      <button class="btn btn-or" onclick="openModal('modal-participant')">+ Ajouter manuellement</button>
    </div>

    <div class="card">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Nom</th><th>Contact</th><th>Présence</th><th>Transport village</th><th>Contribution</th><th>Note</th><th>Action</th>
            </tr>
          </thead>
          <tbody id="participants-table"><tr><td colspan="7" class="empty">Aucun participant enregistré</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ========== FORMULAIRE ========== -->
  <div class="page" id="page-formulaire">
    <div class="page-header">
      <h1>Formulaire de participation</h1>
      <p>Générer et partager le lien de participation</p>
    </div>

    <div class="share-box">
      <h3>🔗 Lien à partager</h3>
      <p style="color:var(--gris);font-size:0.83rem;margin-bottom:1rem;">
        Partagez ce lien par WhatsApp, SMS ou email. Les personnes pourront indiquer où elles peuvent vous assister.
      </p>
      <div class="link-row">
        <input type="text" class="link-input" id="share-link" readonly value="">
        <button class="btn btn-or btn-sm" onclick="copyLink()">Copier</button>
        <button class="btn btn-outline btn-sm" onclick="shareWhatsApp()">WhatsApp</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Configurer le formulaire</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Nom du défunt</label>
          <input type="text" id="cfg-nom" placeholder="Ex: Papa Jean-Baptiste" oninput="updateFormPreview()">
        </div>
        <div class="form-group">
          <label>Date du deuil</label>
          <input type="date" id="cfg-date" oninput="updateFormPreview()">
        </div>
        <div class="form-group">
          <label>Lieu — Ville</label>
          <input type="text" id="cfg-ville" placeholder="Ex: Douala, Yaoundé..." oninput="updateFormPreview()">
        </div>
        <div class="form-group">
          <label>Lieu — Village</label>
          <input type="text" id="cfg-village" placeholder="Ex: Bafoussam, Ébolowa..." oninput="updateFormPreview()">
        </div>
        <div class="form-group full">
          <label>Message d'invitation (optionnel)</label>
          <textarea id="cfg-message" rows="2" placeholder="Ex: La famille vous invite à nous rejoindre..." oninput="updateFormPreview()"></textarea>
        </div>
      </div>
      <div class="actions">
        <button class="btn btn-or" onclick="saveConfig()">Enregistrer la configuration</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Aperçu du formulaire public</div>
      <div id="form-preview-wrap">
        <div class="public-form-preview" id="public-form-preview">
          <h2>🕊 Deuil de <span id="pv-nom">Djoudjieu Jeannette épse Tapondjou</span></h2>
          <p id="pv-msg">Votre présence est une grande consolation pour la famille.</p>
          <hr style="border-color:#eee;margin:1rem 0;">
          <div class="form-group" style="margin-bottom:1rem;">
            <label>Votre nom complet *</label>
            <input type="text" placeholder="Jean Dupont" disabled>
          </div>
          <div class="form-group" style="margin-bottom:1rem;">
            <label>Téléphone / WhatsApp *</label>
            <input type="text" placeholder="+237 6XX XXX XXX" disabled>
          </div>
          <div class="form-group" style="margin-bottom:1rem;">
            <label>Où pouvez-vous nous assister ? *</label>
            <select disabled>
              <option>-- Choisir --</option>
              <option>À la veillée (ville)</option>
              <option>À la célébration au village</option>
              <option>Les deux (ville + village)</option>
              <option>À distance (soutien moral/financier)</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:1rem;">
            <label>Transport pour aller au village *</label>
            <select disabled>
              <option>-- Choisir --</option>
              <option>🚌 Je prends le bus organisé depuis Douala</option>
              <option>🚗 Je voyage par mes propres moyens</option>
              <option>⛔ Je ne vais pas au village</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom:1rem;">
            <label>Contribution financière prévue (FCFA)</label>
            <input type="number" placeholder="Laisser vide si non concerné" disabled>
          </div>
          <div class="form-group" style="margin-bottom:1.5rem;">
            <label>Message pour la famille</label>
            <textarea rows="2" placeholder="Vos condoléances ou disponibilités..." disabled></textarea>
          </div>
          <button class="btn btn-or" style="width:100%;" disabled>Envoyer ma réponse</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Réponses reçues (<span id="reponses-count">0</span>)</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Nom</th><th>Contact</th><th>Présence</th><th>Transport</th><th>Contribution prévue</th><th>Message</th><th>Action</th></tr>
          </thead>
          <tbody id="reponses-table"><tr><td colspan="7" class="empty">Aucune réponse reçue</td></tr></tbody>
        </table>
      </div>
    </div>
  </div>

</main>

<!-- ========== MODAL TRANSACTION ========== -->
<div class="modal-overlay" id="modal-transaction">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Nouvelle transaction</div>
      <button class="modal-close" onclick="closeModal('modal-transaction')">×</button>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>Type *</label>
        <select id="t-type">
          <option value="entree">Entrée (contribution reçue)</option>
          <option value="depense">Dépense</option>
        </select>
      </div>
      <div class="form-group">
        <label>Montant (FCFA) *</label>
        <input type="number" id="t-montant" placeholder="Ex: 50000">
      </div>
      <div class="form-group">
        <label>Catégorie</label>
        <select id="t-categorie">
          <optgroup label="Entrées">
            <option value="contribution-famille">Contribution famille</option>
            <option value="contribution-ami">Contribution amis/collègues</option>
            <option value="collecte">Collecte/Tontine</option>
          </optgroup>
          <optgroup label="Dépenses">
            <option value="cercueil">Cercueil / Pompes funèbres</option>
            <option value="transport">Transport / Déplacement</option>
            <option value="nourriture">Nourriture / Restauration</option>
            <option value="boisson">Boissons</option>
            <option value="location">Location salle / Chaises</option>
            <option value="habit-deuil">Habits de deuil</option>
            <option value="musique">Musique / Orchestre</option>
            <option value="ceremonie">Cérémonie religieuse</option>
            <option value="impression">Impression / Faire-part</option>
            <option value="autre">Autre</option>
          </optgroup>
        </select>
      </div>
      <div class="form-group">
        <label>Date</label>
        <input type="date" id="t-date">
      </div>
      <div class="form-group full">
        <label>Description</label>
        <input type="text" id="t-description" placeholder="Ex: Don de l'oncle Paul, Achat chaises...">
      </div>
      <div class="form-group">
        <label>Donateur / Bénéficiaire</label>
        <input type="text" id="t-personne" placeholder="Nom de la personne">
      </div>
    </div>
    <div class="actions">
      <button class="btn btn-or" onclick="addTransaction()">Enregistrer</button>
      <button class="btn btn-outline" onclick="closeModal('modal-transaction')">Annuler</button>
    </div>
  </div>
</div>

<!-- ========== MODAL PARTICIPANT ========== -->
<div class="modal-overlay" id="modal-participant">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">Ajouter un participant</div>
      <button class="modal-close" onclick="closeModal('modal-participant')">×</button>
    </div>
    <div class="form-grid">
      <div class="form-group">
        <label>Nom complet *</label>
        <input type="text" id="p-nom" placeholder="Jean Dupont">
      </div>
      <div class="form-group">
        <label>Téléphone</label>
        <input type="text" id="p-tel" placeholder="+237 6XX...">
      </div>
      <div class="form-group">
        <label>Présence prévue</label>
        <select id="p-presence">
          <option value="ville">Veillée en ville</option>
          <option value="village">Célébration au village</option>
          <option value="partout">Ville + Village</option>
          <option value="distance">À distance</option>
        </select>
      </div>
      <div class="form-group">
        <label>Transport pour le village</label>
        <select id="p-transport">
          <option value="bus">🚌 Bus organisé (depuis Douala)</option>
          <option value="propre">🚗 Moyen personnel</option>
          <option value="non">⛔ Ne va pas au village</option>
        </select>
      </div>
      <div class="form-group">
        <label>Contribution prévue (FCFA)</label>
        <input type="number" id="p-contribution" placeholder="0">
      </div>
      <div class="form-group full">
        <label>Note</label>
        <textarea id="p-note" rows="2" placeholder="Informations supplémentaires..."></textarea>
      </div>
    </div>
    <div class="actions">
      <button class="btn btn-or" onclick="addParticipant()">Ajouter</button>
      <button class="btn btn-outline" onclick="closeModal('modal-participant')">Annuler</button>
    </div>
  </div>
</div>

<!-- ========== MODAL FORMULAIRE PUBLIC ========== -->
<div class="modal-overlay" id="modal-public-form">
  <div class="modal" style="max-width:580px;">
    <div class="modal-header">
      <div class="modal-title" style="color:var(--noir);">Formulaire de participation</div>
      <button class="modal-close" onclick="closeModal('modal-public-form')" style="color:#333;">×</button>
    </div>
    <div class="public-form-preview" style="padding:0;">
      <h2 style="padding:1rem 0 0.3rem;">🕊 Deuil de <span id="mf-nom">Djoudjieu Jeannette épse Tapondjou</span></h2>
      <p id="mf-msg" style="padding:0 0 1rem;">Votre présence est une grande consolation.</p>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Votre nom complet *</label>
        <input type="text" id="mf-pnom" placeholder="Jean Dupont">
      </div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Téléphone / WhatsApp *</label>
        <input type="text" id="mf-tel" placeholder="+237 6XX XXX XXX">
      </div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Où pouvez-vous nous assister ? *</label>
        <select id="mf-presence">
          <option value="">-- Choisir --</option>
          <option value="ville">À la veillée (ville)</option>
          <option value="village">À la célébration au village</option>
          <option value="partout">Les deux (ville + village)</option>
          <option value="distance">À distance (soutien moral/financier)</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Transport pour aller au village *</label>
        <select id="mf-transport">
          <option value="">-- Choisir --</option>
          <option value="bus">🚌 Je prends le bus organisé depuis Douala</option>
          <option value="propre">🚗 Je voyage par mes propres moyens</option>
          <option value="non">⛔ Je ne vais pas au village</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Contribution financière prévue (FCFA)</label>
        <input type="number" id="mf-contribution" placeholder="Laisser vide si non concerné">
      </div>
      <div class="form-group" style="margin-bottom:1.5rem;">
        <label>Message pour la famille</label>
        <textarea id="mf-note" rows="2" placeholder="Condoléances, disponibilités..."></textarea>
      </div>
      <button class="btn btn-or" style="width:100%;" onclick="submitPublicForm()">Envoyer ma réponse</button>
    </div>
  </div>
</div>

<div id="toast">✓ Action effectuée</div>

<script>
// ===== STATE =====
let state = {
  transactions: [],
  participants: [],
  config: { nom: 'Djoudjieu Jeannette épse Tapondjou', date: '', ville: '', village: '', message: '' },
};

// Load from localStorage
try {
  const saved = localStorage.getItem('deuil-papa');
  if (saved) state = JSON.parse(saved);
} catch(e) {}

function save() {
  try { localStorage.setItem('deuil-papa', JSON.stringify(state)); } catch(e) {}
}

// ===== NAVIGATION =====
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  event.target.classList.add('active');
  if (id === 'dashboard') renderDashboard();
  if (id === 'finances') renderFinances();
  if (id === 'participants') renderParticipants();
  if (id === 'formulaire') renderFormulaire();
}

// ===== UTILS =====
function fmt(n) {
  return Number(n).toLocaleString('fr-FR') + ' FCFA';
}
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = '✓ ' + msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function presenceBadge(p) {
  const map = {
    ville: ['badge-ville','Veillée — Ville'],
    village: ['badge-village','Village'],
    partout: ['badge-partout','Ville + Village'],
    distance: ['badge-ville','À distance'],
  };
  const [cls, txt] = map[p] || ['badge-ville', p];
  return `<span class="badge ${cls}">${txt}</span>`;
}

// ===== FINANCES =====
function addTransaction() {
  const type = document.getElementById('t-type').value;
  const montant = parseFloat(document.getElementById('t-montant').value);
  const categorie = document.getElementById('t-categorie').value;
  const date = document.getElementById('t-date').value || new Date().toISOString().split('T')[0];
  const description = document.getElementById('t-description').value;
  const personne = document.getElementById('t-personne').value;

  if (!montant || montant <= 0) { alert('Veuillez entrer un montant valide.'); return; }

  state.transactions.push({ id: Date.now(), type, montant, categorie, date, description, personne });
  save();
  closeModal('modal-transaction');
  renderFinances();
  renderDashboard();
  toast('Transaction enregistrée');

  // reset
  ['t-montant','t-description','t-personne'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('t-date').value = '';
}

function deleteTransaction(id) {
  if (!confirm('Supprimer cette transaction ?')) return;
  state.transactions = state.transactions.filter(t => t.id !== id);
  save(); renderFinances(); renderDashboard();
  toast('Transaction supprimée');
}

function renderFinances() {
  const tbody = document.getElementById('finance-table');
  if (!state.transactions.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty">Aucune transaction enregistrée</td></tr>';
    return;
  }
  const sorted = [...state.transactions].sort((a,b) => new Date(b.date) - new Date(a.date));
  tbody.innerHTML = sorted.map(t => `
    <tr>
      <td>${t.date}</td>
      <td><span class="badge ${t.type==='entree'?'badge-entree':'badge-depense'}">${t.type==='entree'?'Entrée':'Dépense'}</span></td>
      <td style="color:var(--gris);font-size:0.8rem;">${t.categorie || '-'}</td>
      <td>${t.description || '-'}${t.personne ? `<br><span style="color:var(--gris);font-size:0.78rem;">${t.personne}</span>` : ''}</td>
      <td class="${t.type==='entree'?'montant-pos':'montant-neg'}" style="font-weight:500;">${t.type==='entree'?'+':'-'} ${fmt(t.montant)}</td>
      <td><button class="btn btn-danger" onclick="deleteTransaction(${t.id})">Suppr.</button></td>
    </tr>
  `).join('');
}

// ===== PARTICIPANTS =====
function addParticipant(data) {
  const p = data || {
    id: Date.now(),
    nom: document.getElementById('p-nom').value,
    tel: document.getElementById('p-tel').value,
    presence: document.getElementById('p-presence').value,
    transport: document.getElementById('p-transport').value,
    contribution: parseFloat(document.getElementById('p-contribution').value) || 0,
    note: document.getElementById('p-note').value,
    source: 'manuel',
  };
  if (!data && !p.nom.trim()) { alert('Le nom est obligatoire.'); return; }
  if (!data) { closeModal('modal-participant'); }
  state.participants.push(p);
  save(); renderParticipants(); renderDashboard();
  toast('Participant ajouté');
  if (!data) ['p-nom','p-tel','p-contribution','p-note'].forEach(id => document.getElementById(id).value = '');
}

function deleteParticipant(id) {
  if (!confirm('Supprimer ce participant ?')) return;
  state.participants = state.participants.filter(p => p.id !== id);
  save(); renderParticipants(); renderDashboard();
  toast('Participant supprimé');
}

function transportBadge(t) {
  if (t === 'bus') return '<span class="badge badge-village">🚌 Bus organisé</span>';
  if (t === 'propre') return '<span class="badge badge-ville">🚗 Moyen perso</span>';
  if (t === 'non') return '<span style="color:var(--gris);font-size:0.8rem;">—</span>';
  return '<span style="color:var(--gris);font-size:0.8rem;">—</span>';
}

function renderParticipants() {
  const tbody = document.getElementById('participants-table');
  if (!state.participants.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="empty">Aucun participant enregistré</td></tr>';
    return;
  }
  tbody.innerHTML = state.participants.map(p => `
    <tr>
      <td>${p.nom}${p.source==='formulaire'?'<br><span style="color:var(--or);font-size:0.72rem;">via formulaire</span>':''}</td>
      <td style="color:var(--gris);font-size:0.83rem;">${p.tel || '-'}</td>
      <td>${presenceBadge(p.presence)}</td>
      <td>${transportBadge(p.transport)}</td>
      <td class="montant-pos">${p.contribution ? fmt(p.contribution) : '-'}</td>
      <td style="color:var(--gris);font-size:0.82rem;max-width:180px;">${p.note || '-'}</td>
      <td><button class="btn btn-danger" onclick="deleteParticipant(${p.id})">Suppr.</button></td>
    </tr>
  `).join('');
}

// ===== DASHBOARD =====
function renderDashboard() {
  const entrees = state.transactions.filter(t=>t.type==='entree').reduce((s,t)=>s+t.montant,0);
  const depenses = state.transactions.filter(t=>t.type==='depense').reduce((s,t)=>s+t.montant,0);
  const solde = entrees - depenses;

  document.getElementById('stat-entrees').textContent = fmt(entrees);
  document.getElementById('stat-depenses').textContent = fmt(depenses);
  document.getElementById('stat-solde').textContent = fmt(solde);
  document.getElementById('stat-solde').className = 'stat-value ' + (solde >= 0 ? 'montant-pos' : 'montant-neg');
  document.getElementById('stat-participants').textContent = state.participants.length;

  // Dernières transactions
  const recent = [...state.transactions].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,5);
  const dt = document.getElementById('dash-transactions');
  if (!recent.length) { dt.innerHTML = '<div class="empty">Aucune transaction</div>'; }
  else {
    dt.innerHTML = recent.map(t => `
      <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
        <span style="font-size:0.85rem;">${t.description||t.categorie||'—'}</span>
        <span class="${t.type==='entree'?'montant-pos':'montant-neg'}" style="font-size:0.85rem;font-weight:500;">${t.type==='entree'?'+':'-'}${fmt(t.montant)}</span>
      </div>
    `).join('');
  }

  // Répartition
  const rp = document.getElementById('dash-repartition');
  const counts = {};
  state.participants.forEach(p => { counts[p.presence] = (counts[p.presence]||0) + 1; });
  const labels = { ville:'Veillée en ville', village:'Village', partout:'Ville + Village', distance:'À distance' };

  const busCnt = state.participants.filter(p=>p.transport==='bus').length;
  const propreCnt = state.participants.filter(p=>p.transport==='propre').length;

  if (!Object.keys(counts).length) {
    rp.innerHTML = '<div class="empty">Aucun participant</div>';
  } else {
    rp.innerHTML = Object.entries(counts).map(([k,v]) => `
      <div style="display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid rgba(255,255,255,0.05);">
        <span style="font-size:0.85rem;">${labels[k]||k}</span>
        <span style="color:var(--or);font-weight:600;">${v}</span>
      </div>
    `).join('') + (busCnt||propreCnt ? `
      <div style="margin-top:0.8rem;padding-top:0.5rem;border-top:1px solid rgba(201,168,76,0.2);">
        <div style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--gris);margin-bottom:0.4rem;">Transport village</div>
        ${busCnt ? `<div style="display:flex;justify-content:space-between;padding:0.4rem 0;font-size:0.85rem;"><span>🚌 Bus organisé</span><span style="color:var(--or);font-weight:600;">${busCnt}</span></div>` : ''}
        ${propreCnt ? `<div style="display:flex;justify-content:space-between;padding:0.4rem 0;font-size:0.85rem;"><span>🚗 Moyen personnel</span><span style="color:var(--or);font-weight:600;">${propreCnt}</span></div>` : ''}
      </div>` : '');
  }

  document.getElementById('dash-date').textContent = 'Mis à jour le ' + new Date().toLocaleDateString('fr-FR', {day:'numeric',month:'long',year:'numeric'});
}

// ===== FORMULAIRE =====
function saveConfig() {
  state.config = {
    nom: document.getElementById('cfg-nom').value || 'Papa',
    date: document.getElementById('cfg-date').value,
    ville: document.getElementById('cfg-ville').value,
    village: document.getElementById('cfg-village').value,
    message: document.getElementById('cfg-message').value,
  };
  save();
  updateFormPreview();
  generateShareLink();
  toast('Configuration sauvegardée');
}

function updateFormPreview() {
  const nom = document.getElementById('cfg-nom').value || 'Djoudjieu Jeannette épse Tapondjou';
  const msg = document.getElementById('cfg-message').value || 'Votre présence est une grande consolation pour la famille.';
  document.getElementById('pv-nom').textContent = nom;
  document.getElementById('pv-msg').textContent = msg;
}

function generateShareLink() {
  // Encode config in URL hash for simulation
  const cfg = encodeURIComponent(JSON.stringify(state.config));
  const base = window.location.href.split('?')[0].split('#')[0];
  const link = base + '?formulaire=1&cfg=' + cfg;
  document.getElementById('share-link').value = link;
  return link;
}

function copyLink() {
  const link = document.getElementById('share-link').value;
  if (!link) { toast('Configurez d\'abord le formulaire'); return; }
  navigator.clipboard.writeText(link).then(() => toast('Lien copié !')).catch(() => {
    document.getElementById('share-link').select();
    document.execCommand('copy');
    toast('Lien copié !');
  });
}

function shareWhatsApp() {
  const link = document.getElementById('share-link').value;
  if (!link) { toast('Configurez d\'abord le formulaire'); return; }
  const nom = state.config.nom || 'Papa';
  const msg = encodeURIComponent(`Chers proches,\nNous traversons un moment difficile avec le deuil de ${nom}.\nMerci de remplir ce formulaire pour nous indiquer comment vous pouvez nous assister :\n${link}`);
  window.open('https://wa.me/?text=' + msg, '_blank');
}

function renderFormulaire() {
  // populate config fields
  document.getElementById('cfg-nom').value = state.config.nom || 'Djoudjieu Jeannette épse Tapondjou';
  document.getElementById('cfg-date').value = state.config.date || '';
  document.getElementById('cfg-ville').value = state.config.ville || '';
  document.getElementById('cfg-village').value = state.config.village || '';
  document.getElementById('cfg-message').value = state.config.message || '';
  updateFormPreview();
  generateShareLink();
  renderReponses();
}

function renderReponses() {
  const reponses = state.participants.filter(p => p.source === 'formulaire');
  document.getElementById('reponses-count').textContent = reponses.length;
  const tbody = document.getElementById('reponses-table');
  if (!reponses.length) {
    tbody.innerHTML = '<tr><td colspan="7" class="empty">Aucune réponse reçue</td></tr>';
    return;
  }
  tbody.innerHTML = reponses.map(p => `
    <tr>
      <td>${p.nom}</td>
      <td style="color:var(--gris);font-size:0.83rem;">${p.tel||'-'}</td>
      <td>${presenceBadge(p.presence)}</td>
      <td>${transportBadge(p.transport)}</td>
      <td class="montant-pos">${p.contribution ? fmt(p.contribution) : '-'}</td>
      <td style="color:var(--gris);font-size:0.82rem;max-width:150px;">${p.note||'-'}</td>
      <td><button class="btn btn-danger" onclick="deleteParticipant(${p.id});renderReponses();">Suppr.</button></td>
    </tr>
  `).join('');
}

// DEMO: Simulate someone filling the public form
function submitPublicForm() {
  const nom = document.getElementById('mf-pnom').value.trim();
  const tel = document.getElementById('mf-tel').value.trim();
  const presence = document.getElementById('mf-presence').value;
  const contribution = parseFloat(document.getElementById('mf-contribution').value) || 0;
  const note = document.getElementById('mf-note').value;

  const transport = document.getElementById('mf-transport').value;

  if (!nom) { alert('Le nom est obligatoire.'); return; }
  if (!presence) { alert('Veuillez indiquer où vous pouvez assister.'); return; }

  const p = { id: Date.now(), nom, tel, presence, transport, contribution, note, source: 'formulaire' };
  state.participants.push(p);
  save();
  closeModal('modal-public-form');
  renderParticipants();
  renderDashboard();
  renderReponses();
  toast('Réponse enregistrée — Merci !');

  ['mf-pnom','mf-tel','mf-contribution','mf-note'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('mf-presence').value = '';
}

// Check if URL has ?formulaire=1 (simulate public form link opening)
if (window.location.search.includes('formulaire=1')) {
  try {
    const params = new URLSearchParams(window.location.search);
    const cfg = JSON.parse(decodeURIComponent(params.get('cfg')||'{}'));
    document.getElementById('mf-nom').textContent = cfg.nom || 'Papa';
    document.getElementById('mf-msg').textContent = cfg.message || 'Votre présence est une grande consolation pour la famille.';
  } catch(e) {}
  // Show modal
  setTimeout(() => openModal('modal-public-form'), 300);
}

// DEMO link: clicking preview button
document.querySelector('#public-form-preview button').removeAttribute('disabled');
document.querySelector('#public-form-preview button').onclick = () => {
  document.getElementById('mf-nom').textContent = document.getElementById('cfg-nom').value || 'Papa';
  document.getElementById('mf-msg').textContent = document.getElementById('cfg-message').value || 'Votre présence est une grande consolation pour la famille.';
  openModal('modal-public-form');
};

// Init
document.getElementById('t-date').value = new Date().toISOString().split('T')[0];
renderDashboard();
generateShareLink();
</script>
</body>
</html>
